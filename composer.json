{
    "name": "twilio-sms-sdk",
    "description": "A PHP SDK for sending SMS messages via Twilio",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "Carl William",
            "email": "xtrsoftwares@gmail.com"
        }
    ],
    "require": {
        "php": ">=7.4",
        "twilio/sdk": "^7.0",
        "psr/log": "^3.0",
        "guzzlehttp/guzzle": "^7.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^9.6",
        "mockery/mockery": "^1.6",
        "phpstan/phpstan": "^1.10",
        "squizlabs/php_codesniffer": "^3.8"
    },
    "autoload": {
        "psr-4": {
            "TwilioSMS\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "TwilioSMS\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit",
        "lint": "phpcs --standard=PSR12 src/",
        "stan": "phpstan analyse src/ --level=5"
    },
    "minimum-stability": "stable"
}
